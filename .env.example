# Runtime
APP_TIMEZONE=Asia/Shanghai
CONFIG_PATH=config.yaml
OUTPUT_DIR=reports
LOG_FILE=logs/daily.log
RUN_DAILY_TIMEOUT=45m

# PDF
# PDF is generated from HTML by wkhtmltopdf first, then validated before push.
ENABLE_PDF=true
PDF_WKHTMLTOPDF_PATH=
PDF_MIN_BYTES=5000

# Market data
# Full report provider order is tried in order: FMP -> Twelve Data -> yfinance -> local cache.
# Stooq is disabled by default because CSV availability is unstable; set ENABLE_STOOQ=true only when you want to test it explicitly.
# Do not shrink the universe to bypass data failures. Upgrade/add formal providers when the full pool is incomplete.
MARKET_DATA_PROVIDER_ORDER=fmp,twelve_data,yfinance,cache
ENABLE_STOOQ=false
FMP_API_KEY=
TWELVE_DATA_API_KEY=
MARKET_REQUEST_DELAY_SEC=0.2
MARKET_RETRY_COUNT=2
MARKET_RETRY_BACKOFF_SEC=30.0
# Only HTTP 429/rate_limited waits and retries. FMP HTTP 402 falls through to Twelve Data immediately.
MARKET_PROVIDER_REQUEST_TIMEOUT_SEC=12
MARKET_PER_TICKER_TIMEOUT_SEC=60
MARKET_FETCH_TIMEOUT_SEC=1200
TWELVE_DATA_BATCH_SIZE=3
TWELVE_DATA_BATCH_SLEEP_SEC=90
TWELVE_DATA_RETRY_SLEEP_SEC=90
MARKET_RUN_STATE_PATH=data/processed/market_run_state.json
MARKET_CACHE_DIR=data/processed/market_cache
MARKET_CACHE_SNAPSHOT_PATH=data/processed/market_cache.json
MARKET_CACHE_MAX_AGE_HOURS=168
# Formal reports may use cache only when its latest date is within the most recent 3 trading days.
MARKET_CACHE_MAX_TRADING_DAYS=3
MARKET_MIN_SUCCESS_RATIO=0.9
# Formal reports also require enough live/recent provider data; cache is only a fallback, not the report body.
MARKET_LIVE_MIN_SUCCESS_RATIO=0.7
MARKET_CACHE_MAX_SUCCESS_RATIO=0.3

# Provider check quick mode should not consume the full daily quote budget.
PROVIDER_CHECK_REQUEST_TIMEOUT_SEC=8
PROVIDER_CHECK_REQUEST_DELAY_SEC=0.05

# Future paid/official providers can be wired in later without changing secrets in code.
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=

# Push timeout shared by Telegram and Feishu.
PUSH_TIMEOUT_SEC=30

# Telegram Bot push
# Create a bot with @BotFather, then get your chat id.
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=
TELEGRAM_SEND_MARKDOWN=true
TELEGRAM_SEND_PDF=true

# Feishu/Lark incoming webhook push
# FEISHU_SECRET is optional. Fill it only when the webhook has signature enabled.
ENABLE_FEISHU=false
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=
FEISHU_TEXT_LIMIT=3000

# Email delivery, optional fallback.
ENABLE_EMAIL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
EMAIL_TO=
EMAIL_SUBJECT_PREFIX=美股复盘
